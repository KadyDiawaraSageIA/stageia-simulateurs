function exemplesCR(){
  var ex={cr_ventes_march:800000,cr_ventes_prod:0,cr_services:200000,cr_subventions:0,cr_autres_prod:50000,cr_achats_march:400000,cr_achats_mp:0,cr_var_stocks:0,cr_salaires:200000,cr_charges_soc:30000,cr_loyer:60000,cr_energie:20000,cr_marketing:30000,cr_assurances:10000,cr_transport:15000,cr_autres_charges:25000,cr_amort:40000,cr_provisions:0,cr_interets:30000,cr_autres_fin:0,cr_prod_fin:0,cr_is:0};
  Object.keys(ex).forEach(function(k){var e=document.getElementById(k);if(e)e.value=ex[k]||'';});
  document.getElementById('cr_soc').value='MALI TECH SARL';
  document.getElementById('cr_periode').value='2025';
  calcCR();
