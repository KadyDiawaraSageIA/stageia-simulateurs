<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stageia — Pricing Freelance</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:Arial,sans-serif;background:#f0f0f0;padding:12px;color:#1a1a1a}
h1{background:linear-gradient(135deg,#0D0B2E,#3730A3);color:#fff;padding:16px 20px;border-radius:10px;margin-bottom:14px;font-size:15px}
h1 small{display:block;font-size:11px;color:#AFA9EC;font-weight:400;margin-top:3px}
.tabs{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:14px}
.tab{padding:7px 13px;border:none;background:#ddd;color:#555;border-radius:7px;cursor:pointer;font-size:12px;font-family:Arial;font-weight:500}
.tab.on{background:#8B5CF6;color:#fff}
.pane{display:none;background:#fff;border-radius:10px;padding:16px;border:1px solid #ddd}
.pane.on{display:block}
.row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.row.r3{grid-template-columns:1fr 1fr 1fr}
label{font-size:11px;color:#666;font-weight:600;display:block;margin-bottom:4px}
input,select{width:100%;padding:8px 10px;border:1px solid #ccc;border-radius:7px;font-size:13px;font-family:Arial;background:#fff}
input:focus,select:focus{outline:none;border-color:#8B5CF6}
.hint{font-size:10px;color:#888;margin-top:3px}
.kpis{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:8px;margin:12px 0}
.kpi{background:#f5f5f5;border-radius:8px;padding:10px;text-align:center;border:1px solid #e0e0e0}
.kpi b{display:block;font-size:18px;color:#7C3AED;margin-bottom:2px}
.kpi span{font-size:10px;color:#666}
.box{background:#F5F3FF;border-left:3px solid #8B5CF6;border-radius:0 8px 8px 0;padding:10px 12px;margin-bottom:8px;font-size:12px;line-height:1.6}
.ok{background:#D1FAE5;border-left-color:#10B981;color:#065F46}
.warn{background:#FEF3C7;border-left-color:#F59E0B;color:#92400E}
.err{background:#FEE2E2;border-left-color:#EF4444;color:#991B1B}
.info{background:#DBEAFE;border-left-color:#3B82F6;color:#1E40AF}
table{width:100%;border-collapse:collapse;font-size:12px;margin:10px 0}
th{background:#EDE9FE;padding:8px;text-align:left;font-weight:600;color:#5B21B6}
td{padding:8px;border-bottom:1px solid #eee}
tr.hl td{background:#F5F3FF;font-weight:700;color:#7C3AED}
.pack{border:2px solid #DDD;border-radius:10px;padding:14px;margin-bottom:10px}
.pack.pop{border-color:#8B5CF6}
.pack h3{font-size:14px;color:#5B21B6;margin-bottom:4px}
.pack .prix{font-size:22px;font-weight:700;color:#7C3AED;margin:6px 0}
.pack ul{font-size:11px;color:#555;padding-left:16px;line-height:2}
.pop-badge{background:#8B5CF6;color:#fff;font-size:10px;padding:2px 8px;border-radius:10px;display:inline-block;margin-bottom:6px}
.bar-row{display:flex;align-items:center;gap:8px;margin-bottom:6px;font-size:11px}
.bar-lbl{width:130px;flex-shrink:0;color:#555}
.bar-track{flex:1;height:16px;background:#eee;border-radius:8px;overflow:hidden}
.bar-fill{height:100%;background:#8B5CF6;border-radius:8px;display:flex;align-items:center;padding-left:6px;font-size:9px;color:#fff;font-weight:600}
.devis-ligne{display:grid;grid-template-columns:2fr 60px 100px auto;gap:6px;align-items:center;margin-bottom:6px}
.btn-add{padding:7px 14px;background:#8B5CF6;color:#fff;border:none;border-radius:7px;cursor:pointer;font-size:12px;font-family:Arial;margin-top:6px}
.btn-del{padding:4px 8px;border:1px solid #ddd;background:#fff;border-radius:6px;cursor:pointer;font-size:11px;color:#999;font-family:Arial}
.btn-pdf{width:100%;padding:11px;background:#8B5CF6;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:13px;font-weight:600;font-family:Arial;margin-top:10px}
.sc-btns{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.sc-btn{padding:7px 14px;border:1px solid #ddd;border-radius:7px;background:#fff;color:#555;font-size:12px;cursor:pointer;font-family:Arial}
.sc-btn.on{background:#8B5CF6;color:#fff;border-color:#8B5CF6}
@media(max-width:550px){.row,.row.r3{grid-template-columns:1fr}.devis-ligne{grid-template-columns:1fr 1fr}}
</style>
</head>
<body>

<h1>💼 Simulateur Pricing Freelance — Stageia
<small>Tarif horaire · Packs services · Devis PDF · Benchmarks Mali · Projections revenus</small></h1>

<div class="tabs">
  <button class="tab on" onclick="show(0)">⚙️ Profil</button>
  <button class="tab" onclick="show(1)">💰 Tarif</button>
  <button class="tab" onclick="show(2)">📦 Packs</button>
  <button class="tab" onclick="show(3)">📄 Devis</button>
  <button class="tab" onclick="show(4)">📊 Benchmarks</button>
  <button class="tab" onclick="show(5)">📈 Projections</button>
  <button class="tab" onclick="show(6)">💡 Conseils</button>
</div>

<!-- PANE 0: PROFIL -->
<div class="pane on" id="p0">
  <div class="row">
    <div><label>Votre nom / marque</label><input id="nomF" placeholder="Ex: Kady D. | Studio Mali" oninput="calc()"></div>
    <div><label>Spécialité</label>
    <select id="spec" onchange="calc()">
      <option value="dev">Développement Web</option>
      <option value="design">Design Graphique</option>
      <option value="marketing">Marketing Digital</option>
      <option value="redaction">Rédaction / Copywriting</option>
      <option value="data">Data / Analytics</option>
      <option value="video">Vidéo / Photo</option>
      <option value="formation">Formation / Coaching</option>
      <option value="conseil">Conseil / Consulting</option>
    </select></div>
  </div>
  <div class="row">
    <div><label>Niveau</label>
    <select id="niv" onchange="calc()">
      <option value="0.7">Débutant (0-1 an)</option>
      <option value="0.85">Junior (1-3 ans)</option>
      <option value="1.0">Confirmé (3-6 ans)</option>
      <option value="1.3">Expert (6+ ans)</option>
    </select></div>
    <div><label>Marché principal</label>
    <select id="march" onchange="calc()">
      <option value="mali">Mali / UEMOA</option>
      <option value="afrique">Afrique francophone</option>
      <option value="international">International / Upwork</option>
    </select></div>
  </div>
  <div class="row">
    <div><label>Charges perso / mois (FCFA)</label><input type="number" id="chP" value="150000" oninput="calc()"><div class="hint">Loyer + nourriture + transport</div></div>
    <div><label>Charges pro / mois (FCFA)</label><input type="number" id="chPr" value="50000" oninput="calc()"><div class="hint">Internet + outils + logiciels</div></div>
  </div>
  <div class="row">
    <div><label>Épargne cible / mois (FCFA)</label><input type="number" id="ep" value="50000" oninput="calc()"></div>
    <div><label>Heures facturables / jour</label><input type="number" id="hj" value="6" min="1" max="12" oninput="calc()"><div class="hint">Pas toutes vos heures sont facturées</div></div>
  </div>
  <div class="row">
    <div><label>Jours travaillés / semaine</label><input type="number" id="jS" value="5" min="1" max="7" oninput="calc()"></div>
    <div><label>Taux occupation cible (%)</label><input type="number" id="tO" value="70" min="10" max="100" oninput="calc()"><div class="hint">% du temps en mission payée</div></div>
  </div>
  <div class="kpis" id="kp0"></div>
</div>

<!-- PANE 1: TARIF -->
<div class="pane" id="p1">
  <div class="box info">💡 Ce calcul part de vos besoins réels pour trouver le tarif minimum en dessous duquel vous ne pouvez pas travailler.</div>
  <table id="tarifTable"></table>
  <div id="tarifsRec"></div>
</div>

<!-- PANE 2: PACKS -->
<div class="pane" id="p2">
  <div class="box info">💡 Les forfaits sont plus rentables que la facturation à l'heure. Le client comprend mieux ce qu'il achète.</div>
  <div id="packsBox"></div>
  <div class="box" style="margin-top:10px">🎯 <b>Règle du 3 :</b> Proposez toujours 3 options. 60% des clients choisissent l'option du milieu — positionnez votre offre idéale au centre.</div>
</div>

<!-- PANE 3: DEVIS -->
<div class="pane" id="p3">
  <div class="row">
    <div><label>Nom du client</label><input id="client" placeholder="Ex: Boutique Aminata SARL" oninput="calc()"></div>
    <div><label>Objet du devis</label><input id="obj" placeholder="Ex: Création site web + logo" oninput="calc()"></div>
  </div>
  <div class="row">
    <div><label>N° devis</label><input id="dNum" placeholder="DEV-2025-001" oninput="calc()"></div>
    <div></div>
  </div>
  <div id="lignesBox"></div>
  <button class="btn-add" onclick="addLigne()">+ Ajouter une prestation</button>
  <div id="devisApercu" style="margin-top:14px"></div>
  <button class="btn-pdf" onclick="exportPDF()">🖨️ Imprimer / Sauvegarder PDF</button>
</div>

<!-- PANE 4: BENCHMARKS -->
<div class="pane" id="p4">
  <div class="box info">📊 Tarifs horaires pratiqués sur le marché malien 2025</div>
  <div id="benchBox"></div>
  <div style="margin-top:14px;font-size:12px;font-weight:600;color:#555;margin-bottom:8px">🌍 Comparaison des marchés — votre spécialité</div>
  <div id="marchesBox"></div>
</div>

<!-- PANE 5: PROJECTIONS -->
<div class="pane" id="p5">
  <div class="sc-btns">
    <button class="sc-btn on" id="sc0" onclick="setSc(0)">📉 Prudent 50%</button>
    <button class="sc-btn" id="sc1" onclick="setSc(1)">📊 Réaliste 70%</button>
    <button class="sc-btn" id="sc2" onclick="setSc(2)">🚀 Optimiste 90%</button>
  </div>
  <div class="kpis" id="kpProj"></div>
  <div id="projChart"></div>
  <div id="jalons" style="margin-top:14px"></div>
</div>

<!-- PANE 6: CONSEILS -->
<div class="pane" id="p6">
  <div class="box">💰 <b>Ne jamais baisser vos tarifs</b> — négociez sur la portée du projet (moins de pages, moins de révisions) plutôt que sur le prix.</div>
  <div class="box">📝 <b>Toujours un devis signé + acompte 30-50%</b> avant de démarrer. Protège contre les clients qui disparaissent.</div>
  <div class="box">🎯 <b>Spécialisez-vous dans 1-2 secteurs</b> (ex: sites web pour restaurants). Les spécialistes gagnent 2-3x plus que les généralistes.</div>
  <div class="box">🌍 <b>Upwork / Fiverr</b> pour les clients internationaux. Un bon profil peut vous rapporter 5-10x votre tarif malien.</div>
  <div class="box">📅 <b>Proposez des retainers mensuels</b> à vos bons clients. Revenu récurrent = stabilité.</div>
  <div class="box">⭐ <b>Demandez un témoignage</b> après chaque projet réussi. Ces témoignages justifient des tarifs plus élevés.</div>
  <div class="box">📈 <b>Augmentez vos tarifs tous les 6-12 mois.</b> Prévenez 1 mois à l'avance et justifiez par vos nouvelles compétences.</div>
  <div style="margin-top:14px;font-size:13px;font-weight:600;color:#A32D2D;margin-bottom:8px">🚫 Erreurs fatales à éviter</div>
  <div class="box err">❌ Sous-estimer ses tarifs par peur — vous attirez de mauvais clients</div>
  <div class="box err">❌ Donner des devis verbaux — toujours par écrit, toujours signé</div>
  <div class="box err">❌ Commencer sans acompte</div>
  <div class="box err">❌ Révisions illimitées sans contrat — votre pire ennemi</div>
  <div class="box err">❌ Ne pas augmenter ses tarifs pendant des années</div>
  <div class="box err">❌ Faire des réductions pour la famille/amis sans limites</div>
</div>

<script>
var lignes=[];
var curSc=0;

var BENCH={
  dev:{mali:5000,afrique:8000,international:25000},
  design:{mali:4000,afrique:6000,international:20000},
  marketing:{mali:3500,afrique:5500,international:18000},
  redaction:{mali:2500,afrique:4000,international:12000},
  data:{mali:5000,afrique:8000,international:28000},
  video:{mali:4500,afrique:7000,international:22000},
  formation:{mali:10000,afrique:15000,international:35000},
  conseil:{mali:8000,afrique:12000,international:40000}
};

var PACKS={
  dev:[
    {nom:'Starter 🚀',prix:150000,desc:'Site vitrine simple',items:['5 pages responsive','Formulaire contact','Hébergement 1 an','Délai : 1-2 semaines']},
    {nom:'Business 💼',prix:350000,desc:'Site professionnel WordPress',items:['10 pages + blog','SEO + Analytics','2 révisions incluses','Délai : 3-4 semaines'],pop:true},
    {nom:'E-commerce 🛒',prix:650000,desc:'Boutique en ligne',items:['WooCommerce complet','Orange Money intégré','Formation gestion 2h','Délai : 5-6 semaines']}
  ],
  design:[
    {nom:'Logo 🎨',prix:50000,desc:'Identité de base',items:['3 concepts','2 révisions','PNG + SVG','Délai : 3-5 jours']},
    {nom:'Identité 🏷️',prix:150000,desc:'Branding complet',items:['Logo + charte','Carte de visite','Templates réseaux','Délai : 1-2 sem'],pop:true},
    {nom:'Premium ⭐',prix:300000,desc:'Branding full service',items:['Tout Identité','Packaging','Guide de marque','Délai : 3-4 sem']}
  ],
  marketing:[
    {nom:'Lancement 📣',prix:100000,desc:'Démarrage réseaux',items:['2 comptes configurés','10 posts lancement','Stratégie 1 mois','Délai : 1 semaine']},
    {nom:'Mensuel 📅',prix:200000,desc:'Gestion mensuelle',items:['20 posts/mois','Stories quotidiennes','1 campagne Facebook','Rapport mensuel'],pop:true},
    {nom:'Growth 🚀',prix:400000,desc:'Croissance accélérée',items:['Tout Mensuel','Budget pub 50k inclus','4 Reels/mois','Coaching mensuel']}
  ],
  redaction:[
    {nom:'Contenu ✍️',prix:75000,desc:'5 articles blog',items:['500 mots/article','SEO de base','2 révisions','Délai : 1 semaine']},
    {nom:'Pro 📝',prix:150000,desc:'Contenu premium',items:['10 articles SEO','5 pages web','Newsletter x2','Délai : 2 sem'],pop:true},
    {nom:'Éditorial 🏆',prix:300000,desc:'Stratégie complète',items:['20 contenus/mois','Stratégie éditoriale','Social media copy','Reporting mensuel']}
  ],
  data:[
    {nom:'Dashboard 📊',prix:120000,desc:'Tableau de bord',items:['5 KPIs visualisés','Excel ou Sheets','Formation 1h','Délai : 3-5 jours']},
    {nom:'Analyse 🔬',prix:280000,desc:'Analyse complète',items:['Audit données','Dashboard interactif','Recommandations','Délai : 1-2 sem'],pop:true},
    {nom:'BI Premium ⚡',prix:550000,desc:'Business Intelligence',items:['Power BI / Tableau','Connexion BDD','Automatisation','Formation équipe']}
  ],
  video:[
    {nom:'Social 📱',prix:80000,desc:'3 vidéos réseaux',items:['60 secondes/vidéo','Montage + sous-titres','Thumbnail pro','Délai : 3-5 jours']},
    {nom:'Corporate 🎬',prix:200000,desc:'Vidéo entreprise',items:['Vidéo 2-3 min','Motion design','2 révisions','Délai : 1-2 sem'],pop:true},
    {nom:'Production 🏆',prix:450000,desc:'Tournage complet',items:['Journée tournage','5 vidéos montées','Photos pro incluses','2-3 semaines']}
  ],
  formation:[
    {nom:'Atelier 🎓',prix:50000,desc:'Formation courte',items:['Demi-journée 4h','Support PDF','Exercices pratiques','Max 10 personnes']},
    {nom:'Formation 📚',prix:150000,desc:'Formation intensive',items:['2 jours complets','Certificat Stageia','Suivi 1 mois','Max 15 personnes'],pop:true},
    {nom:'Sur Mesure 🏆',prix:500000,desc:'Programme entreprise',items:['Programme perso','Durée adaptée','Outils créés','Suivi 3 mois']}
  ],
  conseil:[
    {nom:'Audit Flash ⚡',prix:100000,desc:'Diagnostic rapide',items:['Réunion 2h + rapport','10 recommandations','Plan d\'action','Délai : 3-5 jours']},
    {nom:'Mission 💼',prix:350000,desc:'Consulting mensuel',items:['4 sessions x2h','Plan détaillé','Suivi implémentation','Rapport mensuel'],pop:true},
    {nom:'Premium 🏆',prix:800000,desc:'Accompagnement 3 mois',items:['Accès WhatsApp direct','Sessions illimitées','Réseau inclus','3 mois minimum']}
  ]
};

function show(i){
  document.querySelectorAll('.tab').forEach(function(t,j){t.classList.toggle('on',i===j);});
  document.querySelectorAll('.pane').forEach(function(p,j){p.classList.toggle('on',i===j);});
  calc();
}

function setSc(i){
  curSc=i;
  document.querySelectorAll('.sc-btn').forEach(function(b,j){b.classList.toggle('on',i===j);});
  calc();
}

function g(id,d){var e=document.getElementById(id);if(!e)return d||0;return e.value||d||'';}
function gn(id,d){return parseFloat(g(id))||d||0;}
function fm(n){return Math.round(n).toLocaleString('fr-FR');}
function fmk(n){if(n>=1000000)return (n/1000000).toFixed(1)+'M';if(n>=1000)return Math.round(n/1000)+'K';return Math.round(n).toString();}

function calc(){
  var chP=gn('chP',150000), chPr=gn('chPr',50000), ep=gn('ep',50000);
  var hj=gn('hj',6), jS=gn('jS',5), tO=gn('tO',70)/100;
  var mult=parseFloat(g('niv',1))||1;
  var spec=g('spec','dev'), march=g('march','mali');
  var bench=BENCH[spec]||BENCH.dev;
  var benchH=bench[march]||bench.mali;
  var total=chP+chPr+ep;
  var joursM=jS*4.3;
  var joursF=Math.round(joursM*tO);
  var heuresF=joursF*hj;
  var tarifMin=heuresF>0?Math.ceil(total/heuresF/500)*500:5000;
  var tarifRec=Math.ceil(Math.max(tarifMin,benchH*mult)/500)*500;
  var revM=tarifRec*heuresF;

  // KPIs profil
  var k=document.getElementById('kp0');
  if(k) k.innerHTML='<div class="kpi"><b>'+fm(tarifRec)+'</b><span>Tarif horaire (F)</span></div>'+
    '<div class="kpi"><b>'+fm(revM)+'</b><span>Revenu mensuel (F)</span></div>'+
    '<div class="kpi"><b>'+joursF+'j</b><span>Jours facturés/mois</span></div>'+
    '<div class="kpi"><b>'+heuresF+'h</b><span>Heures facturées/mois</span></div>';

  // Tarif
  var tt=document.getElementById('tarifTable');
  if(tt) tt.innerHTML='<thead><tr><th>Composante</th><th>Montant</th><th>Explication</th></tr></thead><tbody>'+
    '<tr><td>Charges personnelles</td><td>'+fm(chP)+' F</td><td>Loyer + vie courante</td></tr>'+
    '<tr><td>Charges professionnelles</td><td>'+fm(chPr)+' F</td><td>Outils + internet</td></tr>'+
    '<tr><td>Épargne / investissement</td><td>'+fm(ep)+' F</td><td>Sécurité + développement</td></tr>'+
    '<tr class="hl"><td><b>Total besoins mensuels</b></td><td><b>'+fm(total)+' F</b></td><td>Ce que vous devez gagner</td></tr>'+
    '<tr><td>Jours facturables/mois</td><td>'+joursF+' jours</td><td>'+jS+'j × 4.3 × '+Math.round(tO*100)+'%</td></tr>'+
    '<tr><td>Heures facturables/mois</td><td>'+heuresF+'h</td><td>'+joursF+' jours × '+hj+'h</td></tr>'+
    '<tr class="hl"><td><b>Tarif minimum</b></td><td><b>'+fm(tarifMin)+' F/h</b></td><td>'+fm(total)+' ÷ '+heuresF+'h</td></tr>'+
    '</tbody>';

  var tr=document.getElementById('tarifsRec');
  if(tr){
    var t1=tarifRec, t2=Math.ceil(t1*1.3/500)*500, t3=Math.ceil(t1*1.7/500)*500;
    tr.innerHTML='<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-top:12px">'+
      '<div class="kpi" style="border:2px solid #3B82F6"><b style="color:#1D4ED8">'+fm(t1)+'</b><span>Standard Mali</span></div>'+
      '<div class="kpi" style="border:2px solid #8B5CF6"><b>'+fm(t2)+'</b><span>Expert / Complexe</span></div>'+
      '<div class="kpi" style="border:2px solid #10B981"><b style="color:#065F46">'+fm(t3)+'</b><span>International</span></div>'+
      '</div>'+
      (tarifMin<benchH?'<div class="box ok" style="margin-top:10px">✅ Vous pouvez facturer plus ! Le marché paie '+fm(benchH)+' F/h pour votre spécialité.</div>':'<div class="box" style="margin-top:10px">✅ Votre tarif est aligné avec le marché.</div>');
  }

  // Packs
  var pb=document.getElementById('packsBox');
  if(pb){
    var packs=PACKS[spec]||PACKS.dev;
    pb.innerHTML=packs.map(function(p){
      return '<div class="pack'+(p.pop?' pop':'')+'">'+
        (p.pop?'<div class="pop-badge">⭐ POPULAIRE</div><br>':'')+
        '<h3>'+p.nom+'</h3>'+
        '<div style="font-size:11px;color:#666">'+p.desc+'</div>'+
        '<div class="prix">'+fm(p.prix)+' FCFA</div>'+
        '<ul>'+p.items.map(function(i){return '<li>'+i+'</li>';}).join('')+'</ul>'+
        '</div>';
    }).join('');
  }

  // Devis
  var da=document.getElementById('devisApercu');
  if(da){
    var tot=lignes.reduce(function(s,l){return s+l.q*l.p;},0);
    var tva=Math.round(tot*0.18);
    var ttc=tot+tva;
    da.innerHTML='<div style="background:#fff;border:1px solid #ddd;border-radius:10px;padding:18px">'+
      '<div style="border-bottom:3px solid #8B5CF6;padding-bottom:10px;margin-bottom:14px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:8px">'+
      '<div><div style="font-size:16px;font-weight:700;color:#0D0B2E">'+(g('nomF','Votre Nom')||'Votre Nom')+'</div>'+
      '<div style="font-size:11px;color:#666">N° '+g('dNum','DEV-2025-001')+' · '+new Date().toLocaleDateString('fr-FR')+'</div></div>'+
      '<div style="text-align:right;font-size:12px;color:#555"><b>Client :</b> '+(g('client','Client')||'Client')+'<br><b>Objet :</b> '+(g('obj','Prestation')||'Prestation')+'</div>'+
      '</div>'+
      '<table><thead><tr><th>Prestation</th><th>Qté</th><th>Prix unit.</th><th>Total</th></tr></thead><tbody>'+
      (lignes.length?lignes.map(function(l){return '<tr><td>'+(l.d||'—')+'</td><td>'+l.q+'</td><td>'+fm(l.p)+' F</td><td>'+fm(l.q*l.p)+' F</td></tr>';}).join(''):
      '<tr><td colspan="4" style="text-align:center;color:#aaa;padding:16px">Ajoutez des prestations</td></tr>')+
      '<tr><td colspan="3" style="text-align:right;font-weight:600">Sous-total HT</td><td>'+fm(tot)+' F</td></tr>'+
      '<tr><td colspan="3" style="text-align:right;color:#666">TVA 18%</td><td>'+fm(tva)+' F</td></tr>'+
      '<tr class="hl"><td colspan="3" style="text-align:right">TOTAL TTC</td><td><b>'+fm(ttc)+' FCFA</b></td></tr>'+
      '</tbody></table>'+
      '<div style="font-size:11px;color:#666;margin-top:10px;line-height:1.8">'+
      '<b>Acompte :</b> 30% à la commande · Solde à la livraison<br>'+
      '<b>Validité :</b> 30 jours · <b>Paiement :</b> Orange Money · Virement · Espèces</div>'+
      '</div>';
  }

  // Benchmarks
  var bb=document.getElementById('benchBox');
  if(bb){
    var specs=[['dev','Dev Web'],['design','Design'],['marketing','Marketing'],['data','Data'],['formation','Formation'],['conseil','Consulting']];
    var maxH=Math.max.apply(null,specs.map(function(s){return BENCH[s[0]].mali;}));
    bb.innerHTML=specs.map(function(s){
      var h=BENCH[s[0]].mali;
      var isAct=s[0]===spec;
      return '<div class="bar-row">'+
        '<div class="bar-lbl" style="'+(isAct?'font-weight:700;color:#7C3AED':'')+'">'+s[1]+(isAct?' ◀':'')+'</div>'+
        '<div class="bar-track"><div class="bar-fill" style="width:'+Math.round(h/maxH*100)+'%;background:'+(isAct?'#8B5CF6':'#3B82F6')+'">'+fm(h)+' F/h</div></div>'+
        '</div>';
    }).join('');
  }

  var mb=document.getElementById('marchesBox');
  if(mb){
    var b=BENCH[spec]||BENCH.dev;
    mb.innerHTML=['mali','afrique','international'].map(function(m){
      var label={mali:'🇲🇱 Mali/UEMOA',afrique:'🌍 Afrique franco.',international:'🌐 International'}[m];
      var h=b[m];
      var isAct=m===march;
      return '<div class="box'+(isAct?' on':'')+'">'+label+' '+(isAct?'◀ <b>Votre marché</b>':'')+
        '<br>Tarif horaire : <b style="color:#7C3AED">'+fm(h)+' F/h</b> · Journée : <b>'+fm(h*hj)+' F</b></div>';
    }).join('');
  }

  // Projections
  var scTaux=[0.5,0.7,0.9];
  var t=scTaux[curSc];
  var jF2=Math.round(joursM*t);
  var hF2=jF2*hj;
  var revBrut=tarifRec*hF2;
  var revNet=revBrut-chP-chPr;

  var kp=document.getElementById('kpProj');
  if(kp) kp.innerHTML='<div class="kpi"><b>'+fm(revBrut)+'</b><span>Revenu brut/mois</span></div>'+
    '<div class="kpi"><b style="color:#0F6E56">'+fm(revNet)+'</b><span>Revenu net/mois</span></div>'+
    '<div class="kpi"><b>'+fmk(revBrut*12)+'</b><span>CA annuel (F)</span></div>'+
    '<div class="kpi"><b>'+Math.round(t*100)+'%</b><span>Taux d\'occupation</span></div>';

  var pc=document.getElementById('projChart');
  if(pc){
    var vals=[];
    for(var i=0;i<12;i++) vals.push(Math.round(revBrut*(1+i*0.02)));
    var maxV=vals[11];
    var mois=['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];
    pc.innerHTML=vals.map(function(v,i){
      return '<div class="bar-row"><div class="bar-lbl">'+mois[i]+'</div>'+
        '<div class="bar-track"><div class="bar-fill" style="width:'+Math.round(v/maxV*100)+'%">'+fmk(v)+' F</div></div></div>';
    }).join('');
  }

  var jb=document.getElementById('jalons');
  if(jb) jb.innerHTML=
    '<div class="box">🌱 <b>Mois 1-2 :</b> Premiers clients, portfolio initial, profil Upwork créé. Objectif : '+Math.round(t*50)+'% occupation.</div>'+
    '<div class="box">📈 <b>Mois 3-4 :</b> 3-5 clients réguliers, premiers témoignages. Objectif : '+fmk(Math.round(revBrut*0.7))+' F/mois.</div>'+
    '<div class="box">💪 <b>Mois 5-6 :</b> 1er client récurrent (retainer). Objectif : '+fmk(Math.round(revBrut*0.9))+' F/mois.</div>'+
    '<div class="box">🚀 <b>Mois 7-12 :</b> Dépasser '+fmk(revBrut)+' F/mois. Spécialisation niche + tarifs premium.</div>';
}

function addLigne(){
  lignes.push({d:'',q:1,p:0});
  renderLignes();
}

function delLigne(i){
  lignes.splice(i,1);
  renderLignes();
  calc();
}

function renderLignes(){
  var el=document.getElementById('lignesBox');
  if(!el) return;
  el.innerHTML=lignes.map(function(l,i){
    return '<div class="devis-ligne">'+
      '<input placeholder="Description de la prestation" value="'+l.d+'" oninput="lignes['+i+'].d=this.value;calc()">'+
      '<input type="number" placeholder="Qté" value="'+l.q+'" oninput="lignes['+i+'].q=parseFloat(this.value)||1;calc()">'+
      '<input type="number" placeholder="Prix (FCFA)" value="'+l.p+'" oninput="lignes['+i+'].p=parseFloat(this.value)||0;calc()">'+
      '<button class="btn-del" onclick="delLigne('+i+')">✕</button>'+
      '</div>';
  }).join('');
}

function exportPDF(){
  var da=document.getElementById('devisApercu');
  if(!da) return;
  var w=window.open('','_blank');
  w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Devis</title>'+
    '<style>*{margin:0;padding:0;box-sizing:border-box}body{font-family:Arial,sans-serif;padding:20px}'+
    'table{width:100%;border-collapse:collapse;font-size:12px;margin:10px 0}'+
    'th{background:#EDE9FE;padding:8px;text-align:left;font-weight:600;color:#5B21B6}'+
    'td{padding:8px;border-bottom:1px solid #eee}'+
    '.hl td{background:#F5F3FF;font-weight:700;color:#7C3AED}'+
    '@media print{@page{margin:1cm;size:A4}}</style>'+
    '</head><body>'+da.innerHTML+'</body></html>');
  w.document.close();
  setTimeout(function(){w.print();},500);
}

// Init
lignes=[{d:'',q:1,p:0}];
renderLignes();
calc();
</script>
