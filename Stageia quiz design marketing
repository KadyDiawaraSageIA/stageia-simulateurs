let state={cat:'design',diff:'all',score:0,xp:0,sessions:0,best:0,badges:0,totalQ:0,totalOk:0};
let curQ=0,questions=[],answers=[],timer=null,timeLeft=0,scores=[];

function setDiff(d){
  document.querySelectorAll('.diff-btn').forEach(b=>b.classList.remove('active'));
  event.target.classList.add('active');
  state.diff=d;
}

function getCats(){return document.getElementById('cats');}
function initCats(){
  getCats().innerHTML=CATS.map(c=>`<button class="cat-btn ${c.id===state.cat?'active':''}" onclick="setCat('${c.id}')" style="${c.id===state.cat?'background:'+c.color+';color:#fff;border-color:'+c.color:''}">${c.icon} ${c.name}</button>`).join('');
}
function setCat(id){
  state.cat=id;
  document.querySelectorAll('.cat-btn').forEach(b=>b.classList.remove('active'));
  const catData=CATS.find(c=>c.id===id);
  const btns=document.querySelectorAll('.cat-btn');
  btns.forEach(b=>{b.style='';if(b.textContent.includes(catData.name)){b.classList.add('active');b.style=`background:${catData.color};color:#fff;border-color:${catData.color}`;}});
  showStart();
}

function showStart(){
  const catData=CATS.find(c=>c.id===state.cat);
  const qs=getFilteredQs();
  document.getElementById('mainArea').innerHTML=`
    <div class="start-card">
      <div style="font-size:40px;margin-bottom:10px">${catData.icon}</div>
      <div class="start-title">${catData.name}</div>
      <div class="start-sub">
        ${qs.length} questions disponibles dans cette catégorie${state.diff!=='all'?' (filtre: '+state.diff+')':''}.<br>
        Chaque question a un chronomètre. Plus vous répondez vite, plus vous gagnez de points bonus !<br>
        Obtenez des badges selon votre performance.
      </div>
      <button class="btn-start" style="background:${catData.color}" onclick="startQuiz()">🚀 Démarrer le Quiz</button>
    </div>`;
}

function getFilteredQs(){
  let qs=QS[state.cat]||[];
  if(state.diff!=='all') qs=qs.filter(q=>q.diff===state.diff);
  return qs;
}

function startQuiz(){
  questions=getFilteredQs();
  if(questions.length===0){document.getElementById('mainArea').innerHTML='<div class="start-card"><div class="start-title">Aucune question dans ce filtre</div><button class="btn-start" onclick="showStart()">Retour</button></div>';return;}
  curQ=0;answers=[];
  state.sessions++;
  renderQ();
}

function renderQ(){
  if(curQ>=questions.length){showBilan();return;}
  const q=questions[curQ];
  const catData=CATS.find(c=>c.id===state.cat);
  const pct=Math.round(curQ/questions.length*100);
  const ans=answers[curQ];
  const xpMax=q.xp||10;

  let optsHTML='';
  if(ans!==undefined){
    optsHTML=q.opts.map((o,i)=>{
      let cls='opt dis';
      if(i===q.correct)cls='opt correct';
      else if(i===ans)cls='opt wrong';
      return `<div class="${cls}"><div class="opt-letter">${String.fromCharCode(65+i)}</div><div class="opt-text">${o}</div></div>`;
    }).join('');
  } else {
    optsHTML=q.opts.map((o,i)=>`<div class="opt" onclick="answerQ(${i})"><div class="opt-letter">${String.fromCharCode(65+i)}</div><div class="opt-text">${o}</div></div>`).join('');
  }

  let fbHTML='';
  if(ans!==undefined){
    const ok=ans===q.correct;
    const xpGained=ok?Math.ceil(xpMax*(timeLeft/30)):0;
    fbHTML=`<div class="fb show ${ok?'good':'bad'}">
      <div class="fb-title">${ok?'✅ Excellente réponse !':'❌ Pas tout à fait...'}</div>
      <div class="fb-text">${q.expl}</div>
      ${q.conseil?`<div class="fb-ref">💡 Conseil pratique : ${q.conseil}</div>`:''}
      ${q.ref?`<div class="fb-ref">📚 Référence : ${q.ref}</div>`:''}
      ${ok?`<div class="xp-gain">+${xpGained} XP gagnés !</div>`:''}
    </div>`;
  }

  document.getElementById('mainArea').innerHTML=`
    <div class="quiz-card">
      <div class="quiz-top">
        <div class="qt-left">
          <div style="width:32px;height:32px;border-radius:50%;background:${catData.color};display:flex;align-items:center;justify-content:center;font-size:15px">${catData.icon}</div>
          <div><div class="qt-cat">${catData.name}</div><div class="qt-num">Question ${curQ+1}/${questions.length}</div></div>
        </div>
        <div style="display:flex;align-items:center;gap:10px">
          <div class="prog-wrap">
            <div class="prog-bar"><div class="prog-fill" style="width:${pct}%"></div></div>
            <div class="prog-txt">${pct}%</div>
          </div>
          <div class="timer" id="timer">${ans!==undefined?'—':'30'}</div>
        </div>
      </div>
      <div class="q-body">
        <span class="q-diff ${q.diff}">${q.diff==='easy'?'⭐ Facile':q.diff==='medium'?'⭐⭐ Intermédiaire':'⭐⭐⭐ Avancé'}</span>
        <span class="q-cat-badge" style="background:${catData.color}22;color:${catData.color}">${catData.icon} ${q.cat||catData.name}</span>
        <div class="q-text">${q.q}</div>
        ${q.tip?`<div class="tip-box"><div class="tip-lbl">💡 Indice</div>${q.tip}</div>`:''}
        <div class="opts">${optsHTML}</div>
        ${fbHTML}
        <button class="btn-next ${ans!==undefined?'show':''}" onclick="nextQ()" style="background:${catData.color}">
          ${curQ<questions.length-1?'Question suivante →':'Voir mon score →'}
        </button>
      </div>
    </div>`;

  if(ans===undefined) startTimer();
}

function startTimer(){
  timeLeft=30;clearInterval(timer);
  const el=document.getElementById('timer');
  if(el) el.textContent=timeLeft;
  timer=setInterval(()=>{
    timeLeft--;
    const el=document.getElementById('timer');
    if(el){el.textContent=timeLeft;el.className='timer'+(timeLeft<=5?' danger':timeLeft<=10?' warn':'');}
    if(timeLeft<=0){clearInterval(timer);if(answers[curQ]===undefined)timeOut();}
  },1000);
}

function timeOut(){
  answers[curQ]=-1;state.totalQ++;
  const q=questions[curQ];
  const catData=CATS.find(c=>c.id===state.cat);
  const optsHTML=q.opts.map((o,i)=>{
    let cls=i===q.correct?'opt correct':'opt dis';
    return `<div class="${cls}"><div class="opt-letter">${String.fromCharCode(65+i)}</div><div class="opt-text">${o}</div></div>`;
  }).join('');
  const qBody=document.querySelector('.q-body');
  if(qBody){
    qBody.querySelector('.opts').innerHTML=optsHTML;
    const fb=document.createElement('div');
    fb.className='fb show bad';
    fb.innerHTML=`<div class="fb-title">⏱️ Temps écoulé !</div><div class="fb-text">La bonne réponse était : ${q.opts[q.correct]}<br><br>${q.expl}</div>`;
    qBody.querySelector('.opts').after(fb);
    const btn=qBody.querySelector('.btn-next');
    if(btn)btn.classList.add('show');
  }
}

function answerQ(i){
  clearInterval(timer);
  const q=questions[curQ];
  const ok=i===q.correct;
  answers[curQ]=i;
  state.totalQ++;
  if(ok){
    const xp=Math.ceil((q.xp||10)*(timeLeft/30));
    state.xp+=xp;state.totalOk++;
    updateStatsDisplay();
  }
  renderQ();
}

function nextQ(){clearInterval(timer);curQ++;renderQ();}

function showBilan(){
  clearInterval(timer);
  const total=questions.length;
  const correct=answers.filter((a,i)=>a===questions[i].correct).length;
  const pct=Math.round(correct/total*100);
  state.sessions++;
  if(pct>state.best){state.best=pct;}
  const catData=CATS.find(c=>c.id===state.cat);
  const ringCls=pct>=90?'exc':pct>=70?'bon':pct>=50?'moy':'fai';
  let msg=pct>=90?`🏆 Exceptionnel ! Vous maîtrisez parfaitement la ${catData.name}. Vous êtes prêt(e) pour le niveau professionnel !`:
          pct>=70?`👍 Très bon score ! Vous avez de solides bases en ${catData.name}. Quelques points à approfondir.`:
          pct>=50?`📚 Score passable. Revisez les questions ratées et recommencez pour progresser.`:
          `🔄 Des lacunes importantes en ${catData.name}. Consultez les ressources recommandées et réessayez.`;

  // Badges
  let badges=[];
  if(pct===100) badges.push({cls:'gold',txt:'🏅 Score Parfait'});
  if(pct>=80) badges.push({cls:'pink',txt:'⭐ Expert '+catData.name});
  if(answers.filter((a,i)=>a!==undefined&&a!==-1&&(Date.now()-answers.answerTime)<5).length>=3) badges.push({cls:'silver',txt:'⚡ Speed Runner'});
  if(state.sessions>=3) badges.push({cls:'silver',txt:'🎓 Assidu(e)'});
  state.badges+=badges.length;

  // Scores leaderboard
  scores.push({name:'Vous',cat:catData.name,score:pct,xp:state.xp});
  scores.sort((a,b)=>b.score-a.score);

  const detail=questions.map((q,i)=>{
    const ok=answers[i]===q.correct;
    return `<div class="detail-item ${ok?'ok':'ko'}">
      <span>${ok?'✅':'❌'}</span>
      <span>${q.q.substring(0,60)}... → ${ok?'Correct':'Bonne réponse : '+q.opts[q.correct].substring(0,40)+'...'}</span>
    </div>`;
  }).join('');

  document.getElementById('mainArea').innerHTML=`
    <div class="bilan-card show">
      <div class="score-ring ${ringCls}">${correct}/${total}</div>
      <div class="bilan-title">${pct>=90?'Expert !':pct>=70?'Excellent !':pct>=50?'Bien essayé !':'À améliorer'}</div>
      <div class="bilan-msg">${msg}</div>
      <div class="bilan-stats">
        <div class="bs"><div class="bs-val">${pct}%</div><div class="bs-lbl">Score</div></div>
        <div class="bs"><div class="bs-val">+${state.xp}</div><div class="bs-lbl">XP gagnés</div></div>
        <div class="bs"><div class="bs-val">${total-correct}</div><div class="bs-lbl">Erreurs</div></div>
      </div>
      ${badges.length>0?`<div class="badge-list">${badges.map(b=>`<div class="badge ${b.cls}">${b.txt}</div>`).join('')}</div>`:''}
      <div class="detail-list">${detail}</div>
      <div class="bilan-btns">
        <button class="btn-retry" onclick="startQuiz()">🔄 Recommencer</button>
        <button class="btn-other" style="background:${catData.color}" onclick="showStart()">Autre catégorie →</button>
      </div>
    </div>`;

  updateStatsDisplay();
  renderLeaderboard();
}

function updateStatsDisplay(){
  document.getElementById('st1').textContent=state.sessions;
  document.getElementById('st2').textContent=state.xp;
  document.getElementById('st3').textContent=state.best+'%';
  document.getElementById('st4').textContent=state.badges;
}

function renderLeaderboard(){
  const lb=document.getElementById('lbList');
  if(!lb)return;
  if(scores.length===0){lb.innerHTML='<div style="text-align:center;color:#888;font-size:12px;padding:10px">Complétez un quiz pour apparaître au classement !</div>';return;}
  lb.innerHTML=scores.slice(0,5).map((s,i)=>`
    <div class="lb-item">
      <div class="lb-rank ${i===0?'r1':i===1?'r2':i===2?'r3':'rn'}">${i+1}</div>
      <div>
        <div class="lb-name">${s.name}</div>
        <div class="lb-cat">${s.cat}</div>
      </div>
      <div class="lb-score">${s.score}%</div>
    </div>`).join('');
}

// Init
initCats();showStart();renderLeaderboard();
</script>
</body>
</html>
