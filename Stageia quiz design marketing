<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stageia — Quiz Design & Marketing</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:Arial,sans-serif;background:#f5f5f5;color:#1a1a1a;padding:16px}
.header{background:linear-gradient(135deg,#0D0B2E,#1a1060);border-radius:12px;padding:18px 22px;margin-bottom:16px;color:#fff;display:flex;align-items:center;gap:12px}
.h-icon{width:44px;height:44px;background:rgba(225,48,108,.25);border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0}
.h-title{font-size:16px;font-weight:600}.h-sub{font-size:11px;color:#AFA9EC;margin-top:3px}
.stats-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:16px}
.stat{background:#fff;border-radius:10px;padding:11px;text-align:center;border:1px solid #e0e0e0}
.stat-val{font-size:22px;font-weight:600;color:#E1306C}
.stat-lbl{font-size:10px;color:#666;margin-top:3px}
.cats{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:16px}
.cat-btn{padding:7px 14px;border:1px solid #ddd;border-radius:20px;background:#fff;color:#555;font-size:12px;cursor:pointer;font-family:Arial;transition:all .15s;display:flex;align-items:center;gap:6px}
.cat-btn:hover{border-color:#E1306C;color:#E1306C}
.cat-btn.active{background:#E1306C;color:#fff;border-color:#E1306C}
.diff-row{display:flex;gap:8px;margin-bottom:16px}
.diff-btn{padding:6px 14px;border:1px solid #ddd;border-radius:8px;background:#fff;color:#555;font-size:12px;cursor:pointer;font-family:Arial}
.diff-btn.active{border-color:#534AB7;background:#EEEDFE;color:#534AB7;font-weight:600}
.start-card{background:#fff;border-radius:12px;padding:24px;text-align:center;border:1px solid #e0e0e0}
.start-title{font-size:17px;font-weight:600;margin-bottom:8px}
.start-sub{font-size:13px;color:#666;line-height:1.6;margin-bottom:20px}
.btn-start{padding:12px 28px;background:#E1306C;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:14px;font-weight:600;font-family:Arial}
.quiz-card{background:#fff;border-radius:12px;border:1px solid #e0e0e0;overflow:hidden}
.quiz-top{background:linear-gradient(135deg,#0D0B2E,#1a1060);padding:14px 18px;display:flex;align-items:center;justify-content:space-between}
.qt-left{display:flex;align-items:center;gap:10px}
.qt-cat{font-size:12px;font-weight:600;color:#fff}
.qt-num{font-size:11px;color:#AFA9EC}
.prog-wrap{display:flex;align-items:center;gap:8px}
.prog-txt{font-size:12px;color:#AFA9EC}
.prog-bar{width:90px;height:5px;background:rgba(255,255,255,.15);border-radius:3px;overflow:hidden}
.prog-fill{height:100%;background:#E1306C;border-radius:3px;transition:width .3s}
.timer{font-size:13px;font-weight:600;color:#fff;background:rgba(255,255,255,.1);padding:4px 10px;border-radius:6px;min-width:40px;text-align:center}
.timer.warn{color:#EF9F27}
.timer.danger{color:#EF4444;animation:blink .5s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.4}}
.q-body{padding:20px}
.q-diff{display:inline-block;padding:2px 9px;border-radius:10px;font-size:10px;font-weight:600;margin-bottom:10px}
.q-diff.easy{background:#D1FAE5;color:#065F46}
.q-diff.medium{background:#FEF3C7;color:#92400E}
.q-diff.hard{background:#FEE2E2;color:#991B1B}
.q-cat-badge{display:inline-block;padding:2px 9px;border-radius:10px;font-size:10px;font-weight:500;margin-bottom:10px;margin-left:6px}
.q-text{font-size:15px;font-weight:600;line-height:1.6;margin-bottom:8px;color:#0D0B2E}
.q-img{width:100%;max-height:160px;object-fit:cover;border-radius:8px;margin-bottom:14px;display:none}
.tip-box{background:#FFF8E1;border-left:3px solid #EF9F27;padding:8px 12px;border-radius:0 8px 8px 0;margin-bottom:14px;font-size:11px;color:#7a5000;line-height:1.5}
.tip-lbl{font-size:10px;font-weight:600;color:#BA7517;margin-bottom:3px}
.opts{display:flex;flex-direction:column;gap:7px;margin-bottom:16px}
.opt{display:flex;align-items:flex-start;gap:10px;padding:11px 14px;border:1px solid #ddd;border-radius:10px;cursor:pointer;transition:all .15s;background:#fff}
.opt:hover{border-color:#E1306C;background:#FFF0F5}
.opt-letter{width:24px;height:24px;border-radius:6px;background:#f5f5f5;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;color:#666;flex-shrink:0;transition:all .15s}
.opt-text{font-size:13px;color:#1a1a1a;line-height:1.5;flex:1}
.opt.correct{border-color:#10B981;background:#E1F5EE}
.opt.correct .opt-letter{background:#10B981;color:#fff}
.opt.wrong{border-color:#EF4444;background:#FEE2E2}
.opt.wrong .opt-letter{background:#EF4444;color:#fff}
.opt.dis{pointer-events:none;opacity:.55}
.fb{border-radius:10px;padding:13px;margin-bottom:14px;display:none}
.fb.show{display:block}
.fb.good{background:#E1F5EE;border:1px solid #10B981}
.fb.bad{background:#FEE2E2;border:1px solid #EF4444}
.fb-title{font-size:13px;font-weight:600;margin-bottom:5px}
.fb.good .fb-title{color:#065F46}
.fb.bad .fb-title{color:#791F1F}
.fb-text{font-size:12px;color:#444;line-height:1.6}
.fb-ref{font-size:11px;color:#888;margin-top:7px;padding-top:7px;border-top:1px solid #e0e0e0}
.xp-gain{display:inline-block;padding:3px 10px;border-radius:10px;font-size:11px;font-weight:600;background:#EEEDFE;color:#534AB7;margin-top:6px}
.btn-next{width:100%;padding:11px;background:#E1306C;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:14px;font-weight:600;display:none;font-family:Arial}
.btn-next.show{display:block}
.bilan-card{background:#fff;border-radius:12px;border:1px solid #e0e0e0;padding:24px;text-align:center;display:none}
.bilan-card.show{display:block}
.score-ring{width:100px;height:100px;border-radius:50%;margin:0 auto 14px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:24px;font-weight:700;border:4px solid #E1306C}
.score-ring.exc{border-color:#10B981;color:#10B981;background:#E1F5EE}
.score-ring.bon{border-color:#534AB7;color:#534AB7;background:#EEEDFE}
.score-ring.moy{border-color:#EF9F27;color:#BA7517;background:#FEF3C7}
.score-ring.fai{border-color:#EF4444;color:#A32D2D;background:#FEE2E2}
.bilan-title{font-size:18px;font-weight:700;margin-bottom:6px}
.bilan-msg{font-size:13px;color:#666;line-height:1.6;margin-bottom:18px;max-width:360px;margin-left:auto;margin-right:auto}
.bilan-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:18px}
.bs{background:#f5f5f5;border-radius:8px;padding:10px}
.bs-val{font-size:20px;font-weight:700;color:#E1306C;margin-bottom:3px}
.bs-lbl{font-size:10px;color:#666}
.badge-list{display:flex;flex-wrap:wrap;gap:8px;justify-content:center;margin-bottom:18px}
.badge{padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600}
.badge.gold{background:#FEF3C7;color:#92400E;border:1px solid #EF9F27}
.badge.silver{background:#f5f5f5;color:#555;border:1px solid #ccc}
.badge.pink{background:#FCE4EC;color:#880E4F;border:1px solid #E1306C}
.detail-list{text-align:left;margin-bottom:18px}
.detail-item{font-size:12px;padding:7px 12px;border-radius:8px;margin-bottom:5px;display:flex;align-items:flex-start;gap:8px;line-height:1.5}
.detail-item.ok{background:#E1F5EE;color:#065F46}
.detail-item.ko{background:#FEE2E2;color:#791F1F}
.bilan-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap}
.btn-retry{padding:9px 20px;border:1px solid #ddd;background:#fff;color:#1a1a1a;border-radius:8px;cursor:pointer;font-size:13px;font-family:Arial}
.btn-other{padding:9px 20px;background:#E1306C;color:#fff;border:none;border-radius:8px;cursor:pointer;font-size:13px;font-family:Arial;font-weight:600}
.leaderboard{background:#fff;border-radius:12px;border:1px solid #e0e0e0;padding:16px;margin-top:16px}
.lb-title{font-size:13px;font-weight:600;margin-bottom:12px;color:#0D0B2E}
.lb-item{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid #f5f5f5}
.lb-item:last-child{border-bottom:none}
.lb-rank{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0}
.lb-rank.r1{background:#FFD700;color:#7a5000}
.lb-rank.r2{background:#C0C0C0;color:#555}
.lb-rank.r3{background:#CD7F32;color:#fff}
.lb-rank.rn{background:#f5f5f5;color:#666}
.lb-name{font-size:13px;font-weight:500;flex:1}
.lb-score{font-size:13px;font-weight:600;color:#E1306C}
.lb-cat{font-size:10px;color:#666}
</style>
</head>
<body>
<div class="header">
  <div class="h-icon">🎨</div>
  <div><div class="h-title">Quiz Design & Marketing — Stageia</div>
  <div class="h-sub">Testez vos connaissances · Progression par niveau · Badges · Classement</div></div>
</div>

<div class="stats-row">
  <div class="stat"><div class="stat-val" id="st1">0</div><div class="stat-lbl">Quiz terminés</div></div>
  <div class="stat"><div class="stat-val" id="st2">0</div><div class="stat-lbl">XP Total</div></div>
  <div class="stat"><div class="stat-val" id="st3">0%</div><div class="stat-lbl">Meilleur score</div></div>
  <div class="stat"><div class="stat-val" id="st4">0</div><div class="stat-lbl">Badges gagnés</div></div>
</div>

<div style="font-size:12px;color:#666;margin-bottom:8px;font-weight:500">Choisissez une catégorie :</div>
<div class="cats" id="cats"></div>
