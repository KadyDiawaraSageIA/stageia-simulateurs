</div>

<script>
const CATS=[
  {id:'design',name:'Design Graphique',icon:'🎨',color:'#E1306C'},
  {id:'marketing',name:'Marketing Digital',icon:'📣',color:'#534AB7'},
  {id:'couleurs',name:'Théorie des Couleurs',icon:'🌈',color:'#EF9F27'},
  {id:'typo',name:'Typographie',icon:'🔤',color:'#3B82F6'},
  {id:'reseaux',name:'Réseaux Sociaux',icon:'📱',color:'#10B981'},
  {id:'branding',name:'Branding & Identité',icon:'🏷️',color:'#8B5CF6'},
];

const QS={
  design:[
    {q:"Quel est le principe de design qui guide l'œil vers l'élément le plus important ?",diff:'easy',cat:'Design',tip:"Pensez à la structure visuelle d'une page — ce qui attire d'abord l'attention.",opts:["L'alignement","La hiérarchie visuelle","La proximité","Le contraste"],correct:1,expl:"La hiérarchie visuelle organise les éléments par ordre d'importance (taille, couleur, poids) pour guider naturellement le regard du lecteur.",conseil:"Utilisez la taille, le poids (gras) et la couleur pour créer 3 niveaux : Titre > Sous-titre > Corps de texte.",ref:"Principe des 6 lois du design graphique — Canons de mise en page.",xp:10},
    {q:"Combien de polices maximum recommande-t-on d'utiliser dans un design professionnel ?",diff:'easy',cat:'Design',tip:"Trop de polices = chaos visuel. Pensez cohérence.",opts:["1 police","2 polices maximum","5 polices","Autant que voulu"],correct:1,expl:"2 polices maximum dans un design professionnel : 1 pour les titres (display ou serif) + 1 pour le corps de texte (sans-serif). Au-delà, le design paraît amateur et incohérent.",conseil:"Règle d'or : 1 police titre + 1 police corps. Variez les graisses (bold, regular, light) pour créer de la hiérarchie.",ref:"Règles typographiques professionnelles — Bringhurst, The Elements of Typographic Style.",xp:10},
    {q:"Qu'est-ce que la 'règle des tiers' en design et photographie ?",diff:'medium',cat:'Design',tip:"Cette règle vient de la photographie et s'applique au design de composition.",opts:["Diviser l'image en 3 couleurs","Diviser la composition en 9 parties égales avec des lignes, placer les éléments importants aux intersections","Utiliser 3 polices différentes","Avoir 3 éléments principaux dans chaque design"],correct:1,expl:"La règle des tiers divise la composition en 9 parties égales (3×3). Les éléments importants sont placés aux 4 intersections ou le long des lignes, créant une composition naturellement harmonieuse.",conseil:"Dans Canva ou Figma, activez la grille d'aide à la composition. Placez votre sujet principal aux intersections des lignes.",ref:"Règle des tiers — Photographie et composition artistique.",xp:15},
    {q:"Qu'est-ce que le 'white space' (espace négatif) en design ?",diff:'medium',cat:'Design',tip:"Ce n'est pas une erreur de design — c'est une décision intentionnelle.",opts:["L'utilisation de couleur blanche uniquement","L'espace vide intentionnel qui respire et met en valeur les éléments","Une faute dans le design qui doit être remplie","L'arrière-plan blanc des documents"],correct:1,expl:"L'espace négatif (white space) est l'espace vide intentionnel autour des éléments. Il améliore la lisibilité, crée une impression de luxe et premium, et met en valeur le contenu principal. Les marques premium en utilisent beaucoup.",conseil:"Si vous pensez avoir assez d'espace dans votre design, doublez-le. Les designs professionnels ont toujours plus d'espace que prévu.",ref:"Jan Tschichold — Design minimaliste. Apple Design Guidelines.",xp:15},
    {q:"Quelle est la signification du 'kerning' en typographie ?",diff:'hard',cat:'Design',tip:"Il s'agit d'un terme technique typographique très spécifique.",opts:["L'espacement entre les lignes de texte","L'ajustement de l'espace entre deux caractères spécifiques","La taille de la police","Le style de la police (gras, italique)"],correct:1,expl:"Le kerning est l'ajustement de l'espace entre deux caractères spécifiques pour améliorer la lisibilité visuelle. Différent du tracking (espacement global) et du leading (interligne). Crucial pour les logos et grands titres.",conseil:"Dans Canva : sélectionnez le texte → Espacement → ajustez. Dans Figma : sélectionnez entre 2 caractères → Option+flèches.",ref:"Terminologie typographique professionnelle. Adobe Fonts Guide.",xp:20},
    {q:"Qu'est-ce que le principe de 'Gestalt' appliqué au design ?",diff:'hard',cat:'Design',tip:"C'est une théorie psychologique qui explique comment le cerveau perçoit les formes.",opts:["Un logiciel de design allemand","Des lois psychologiques expliquant comment notre cerveau regroupe et perçoit les éléments visuels","Une technique de coloration","Un type de mise en page spécifique"],correct:1,expl:"La théorie Gestalt explique comment le cerveau perçoit les éléments visuels comme un tout cohérent. Lois principales : Proximité (éléments proches = liés), Similarité, Continuité, Fermeture (formes incomplètes complétées par le cerveau), Figure/fond.",conseil:"Utilisez la loi de proximité pour grouper les informations liées. Utilisez la loi de similarité pour créer de la cohérence visuelle.",ref:"Théorie de la Gestalt — École de psychologie allemande. Rudolf Arnheim — Art and Visual Perception.",xp:20},
  ],
  marketing:[
    {q:"Qu'est-ce que le 'CTR' (Click-Through Rate) en marketing digital ?",diff:'easy',cat:'Marketing',tip:"C'est une métrique de performance très courante en publicité en ligne.",opts:["Le nombre total de clics","Le pourcentage de personnes qui cliquent sur une annonce par rapport au nombre de vues","Le coût total d'une campagne","Le taux de conversion en vente"],correct:1,expl:"Le CTR = (Clics / Impressions) × 100. Un CTR de 2-3% est bon pour une pub Facebook au Mali. En dessous de 1% = visuels ou ciblage à revoir. Au-dessus de 5% = excellente performance.",conseil:"Pour améliorer le CTR : testez différentes accroches, utilisez des visuels locaux reconnaissables, posez une question dans le titre.",ref:"Facebook Ads Metrics Guide. Google Analytics Academy.",xp:10},
    {q:"Quelle est la règle de contenu recommandée sur les réseaux sociaux ?",diff:'easy',cat:'Marketing',tip:"Il existe une formule célèbre qui équilibre contenu éducatif et promotionnel.",opts:["100% de contenu promotionnel pour vendre","80% de valeur (éducatif/divertissant) + 20% promotionnel","50% promotionnel + 50% éducatif","Uniquement des stories, jamais de posts"],correct:1,expl:"La règle 80/20 : 80% de contenu qui apporte de la valeur (éduquer, divertir, inspirer) + 20% de contenu promotionnel (vendre, offres, produits). Cette règle maintient l'engagement et évite de fatiguer l'audience.",conseil:"Pour Stageia : 80% = conseils emploi, formations, témoignages, tips | 20% = offres, prix, inscriptions.",ref:"Gary Vaynerchuk — Jab, Jab, Jab, Right Hook. Content Marketing Institute.",xp:10},
    {q:"Qu'est-ce que le 'tunnel de vente' (sales funnel) ?",diff:'medium',cat:'Marketing',tip:"Pensez au parcours d'un client depuis la découverte jusqu'à l'achat.",opts:["Une page web de vente unique","Le parcours progressif d'un prospect depuis la découverte jusqu'à l'achat, avec plusieurs étapes","Un logiciel de marketing","Un type de publicité Facebook"],correct:1,expl:"Le tunnel de vente = TOFU (Top) → MOFU (Middle) → BOFU (Bottom). Awareness → Intérêt → Désir → Action. Chaque étape nécessite un contenu adapté : sensibilisation → éducation → conversion. Pour Stageia : post viral → email → offre de formation.",conseil:"Identifiez à quelle étape du tunnel se trouvent vos prospects avant de leur envoyer un message. Un prospect froid ne veut pas voir une offre directe.",ref:"Elias St. Elmo Lewis — AIDA Model. Digital Marketing Institute.",xp:15},
    {q:"Quelle est la différence entre le marketing 'pull' et le marketing 'push' ?",diff:'medium',cat:'Marketing',tip:"Ces deux stratégies ont des directions opposées dans leur approche client.",opts:["Le push est digital et le pull est traditionnel","Le pull attire le client vers la marque (SEO, contenu) ; le push va vers le client (pub, cold email, démarchage)","Le pull est gratuit et le push est payant","Il n'y a pas de différence"],correct:1,expl:"Pull marketing : vous créez du contenu utile qui attire les clients naturellement (SEO, blog, YouTube). Push marketing : vous allez vers le client (publicité, cold calling, emailing de masse). Stratégie optimale : Pull pour construire la confiance + Push pour accélérer.",conseil:"Pour Stageia : créez du contenu éducatif sur l'emploi (pull) + publicités Facebook ciblées (push). Combinez les deux pour maximiser la portée.",ref:"Philip Kotler — Marketing Management. Inbound Marketing Methodology — HubSpot.",xp:15},
    {q:"Qu'est-ce que le 'Net Promoter Score' (NPS) ?",diff:'hard',cat:'Marketing',tip:"C'est l'une des métriques de satisfaction client les plus utilisées au monde.",opts:["Le nombre de nouveaux clients par mois","Un indicateur de la probabilité qu'un client recommande votre produit/service, sur une échelle de 0 à 10","Le pourcentage de clients fidèles","Le score de qualité d'une publicité Facebook"],correct:1,expl:"NPS = % Promoteurs (9-10) - % Détracteurs (0-6). Score > 50 = excellent, > 30 = bon, > 0 = acceptable, < 0 = problème. Question unique : 'Sur une échelle de 0 à 10, recommanderiez-vous notre service à un ami ?'",conseil:"Envoyez un formulaire NPS à vos clients après chaque formation ou service. Un NPS élevé = bouche-à-oreille naturel = acquisition gratuite.",ref:"Fred Reichheld — The Ultimate Question. Harvard Business Review 2003.",xp:20},
    {q:"Quelle est la différence entre une 'audience personnalisée' et une 'audience similaire' sur Facebook Ads ?",diff:'hard',cat:'Marketing',tip:"Ces deux fonctionnalités de ciblage Facebook sont très puissantes mais différentes.",opts:["Ce sont des termes identiques","L'audience personnalisée = vos clients existants (email, téléphone) ; l'audience similaire = personnes ressemblant à vos meilleurs clients, trouvées par l'algorithme Facebook","L'audience personnalisée = plus chère ; l'audience similaire = gratuite","L'audience personnalisée = jeunes ; l'audience similaire = adultes"],correct:1,expl:"Audience personnalisée : upload de vos contacts existants (email/tel) → Facebook trouve les profils correspondants → idéal pour le retargeting et la fidélisation. Audience similaire (Lookalike) : Facebook analyse vos meilleurs clients et trouve 1-10% de personnes similaires au Mali → idéal pour l'acquisition.",conseil:"Stratégie optimale : Créez une audience personnalisée avec vos 100 meilleurs clients → Créez une audience similaire 1% → Testez avec un budget de 2 000 FCFA/jour.",ref:"Facebook Ads Manager Guide — Custom Audiences & Lookalike Audiences.",xp:20},
  ],
  couleurs:[
    {q:"Quelles sont les 3 couleurs primaires en arts graphiques (synthèse soustractive) ?",diff:'easy',cat:'Couleurs',tip:"Ce sont les couleurs de base utilisées en impression.",opts:["Rouge, Vert, Bleu","Cyan, Magenta, Jaune","Rouge, Jaune, Bleu","Orange, Violet, Vert"],correct:2,expl:"En synthèse soustractive (impression) : Cyan, Magenta, Jaune (CMJ). En arts graphiques traditionnels : Rouge, Jaune, Bleu. En écran (synthèse additive) : Rouge, Vert, Bleu (RVB/RGB). Important de connaître les deux systèmes !",conseil:"Pour l'impression professionnelle au Mali, utilisez toujours le mode CMJN dans vos fichiers. Pour les écrans (réseaux sociaux), utilisez RVB.",ref:"Théorie des couleurs — Johannes Itten. Systèmes chromatiques RVB et CMJN.",xp:10},
    {q:"Quelle couleur est traditionnellement associée à la confiance et au professionnalisme ?",diff:'easy',cat:'Couleurs',tip:"Regardez les logos des banques et institutions au Mali — quelle couleur revient le plus ?",opts:["Rouge","Bleu","Jaune","Vert"],correct:1,expl:"Le bleu est universellement associé à la confiance, la fiabilité et le professionnalisme. C'est pourquoi il domine dans la finance (Coris Bank, BMS), la tech (Facebook, LinkedIn) et les institutions. Au Mali, le bleu inspire confiance et sérieux.",conseil:"Pour une startup qui veut paraître crédible rapidement au Mali, intégrez du bleu dans votre identité visuelle.",ref:"Psychologie des couleurs — Eva Heller. Color Psychology in Branding.",xp:10},
    {q:"Qu'est-ce qu'une palette de couleurs 'complémentaire' ?",diff:'medium',cat:'Couleurs',tip:"Regardez un cercle chromatique — les couleurs complémentaires ont une position spécifique.",opts:["Des couleurs qui se ressemblent","Deux couleurs opposées sur le cercle chromatique, créant un fort contraste","Trois couleurs adjacentes sur le cercle","Des couleurs de même teinte mais différentes luminosités"],correct:1,expl:"Les couleurs complémentaires sont opposées sur le cercle chromatique : Rouge/Vert, Bleu/Orange, Jaune/Violet. Elles créent un contraste fort et vibrant, idéal pour les boutons d'action et les accents. Attention : utilisez-les avec parcimonie.",conseil:"Exemples pour Stageia : Violet (#534AB7) + Orange (#EF9F27) = complémentaires. Le violet pour les fonds, l'orange pour les boutons et accents.",ref:"Josef Albers — Interaction of Color. Adobe Color Wheel.",xp:15},
    {q:"Que signifie le code couleur hexadécimal '#FFFFFF' ?",diff:'medium',cat:'Couleurs',tip:"C'est le code couleur le plus basique qui existe — pensez aux extrêmes.",opts:["Noir pur","Blanc pur","Rouge","Gris moyen"],correct:1,expl:"#FFFFFF = Blanc pur (FF en hexadécimal = 255 en décimal, la valeur maximale pour Rouge, Vert et Bleu). #000000 = Noir pur (0,0,0). Chaque paire de chiffres hex correspond à R, G, B. Ex: #E1306C = R(225) G(48) B(108) = Rose/Rouge.",conseil:"Dans Canva : cliquez sur une couleur → tapez directement le code HEX. Enregistrez vos codes HEX de marque dans votre Brand Kit pour ne plus les chercher.",ref:"Système de codification hexadécimale. W3Schools — CSS Colors.",xp:15},
    {q:"Quelle est la signification culturelle du vert au Mali et en Afrique de l'Ouest ?",diff:'hard',cat:'Couleurs',tip:"Au Mali, le contexte religieux et culturel influence fortement la perception des couleurs.",opts:["Danger et avertissement","Symbole de l'Islam, de l'espoir, de la nature et de la prospérité","Deuil et tristesse","Luxe et richesse uniquement"],correct:1,expl:"Au Mali, le vert a une signification culturelle très forte : couleur de l'Islam (très présent au Mali), de l'espoir, de la croissance et de la fertilité. Il évoque aussi la nature et la terre africaine. C'est une couleur extrêmement positive et porteuse de sens dans ce contexte.",conseil:"Pour les produits destinés au marché malien, intégrez le vert si votre marque veut évoquer la croissance, l'espoir ou si elle s'adresse à une clientèle musulmane.",ref:"Psychologie des couleurs en Afrique de l'Ouest. Symbolisme culturel malien.",xp:20},
    {q:"Qu'est-ce que le rapport de contraste WCAG et pourquoi est-il important ?",diff:'hard',cat:'Couleurs',tip:"Il s'agit d'un standard international d'accessibilité numérique.",opts:["Un type de palette de couleurs créatives","Un standard mesurant le contraste entre texte et fond pour l'accessibilité (ratio minimum 4.5:1 pour le texte normal)","Une technique de mélange de couleurs en impression","Le nombre de couleurs maximum dans un design"],correct:1,expl:"WCAG (Web Content Accessibility Guidelines) définit des ratios de contraste minimum pour l'accessibilité : 4.5:1 pour le texte normal, 3:1 pour les grands titres. Un design inaccessible exclut les personnes malvoyantes et peut nuire au référencement.",conseil:"Testez toujours vos combinaisons texte/fond sur webaim.org/resources/contrastchecker avant de publier. Noir sur blanc = 21:1 (parfait). Gris clair sur blanc = souvent insuffisant.",ref:"W3C — WCAG 2.1 Guidelines. WebAIM Contrast Checker.",xp:20},
